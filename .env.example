DATABASE_URL="postgresql://litestats:litestats@localhost:5432/litestats"
AUTH_SECRET="change-me-to-a-random-32-char-string"
HASH_SALT="change-me-to-another-random-string"

# WebAuthn / Passkey（生产环境改为你的域名，必须使用 HTTPS）
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"
WEBAUTHN_RP_NAME="LiteStats"

# GeoIP / 国旗 / Favicon（可选，有默认值）
# GEOIP_API_URL=https://api.cnip.io/geoip
# NEXT_PUBLIC_FLAG_BASE_URL=/flags
# NEXT_PUBLIC_FAVICON_BASE_URL=https://favicon.la

# 生产部署见 .env.production.example 与 deploy/prod-up.sh
