generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  websites     Website[]
  servers      Server[]
  passkeys     Passkey[]

  @@map("users")
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique @map("credential_id")
  publicKey    Bytes     @map("public_key")
  counter      BigInt    @default(0)
  deviceName   String    @map("device_name")
  transports   String[]  @default([])
  backedUp     Boolean   @default(false) @map("backed_up")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")

  @@index([userId])
  @@map("passkeys")
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique
  type      String
  userId    String?  @map("user_id")
  username  String?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("webauthn_challenges")
}

model Website {
  id             String         @id @default(cuid())
  name           String
  domain         String
  trackingId     String         @unique @map("tracking_id")
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitorEnabled Boolean        @default(true) @map("monitor_enabled")
  monitorUrl     String?        @map("monitor_url")
  createdAt      DateTime       @default(now()) @map("created_at")
  sessions       Session[]
  events         Event[]
  monitorChecks  MonitorCheck[]

  @@map("websites")
}

model Session {
  id         String   @id @default(cuid())
  websiteId  String   @map("website_id")
  website    Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  visitorId  String   @map("visitor_id")
  browser    String?
  os         String?
  device     String?
  country    String?
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  events     Event[]

  @@unique([websiteId, visitorId])
  @@index([websiteId, lastSeenAt])
  @@map("sessions")
}

model Event {
  id        String   @id @default(cuid())
  websiteId String   @map("website_id")
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  sessionId String   @map("session_id")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String   @default("pageview")
  url       String?
  path      String?
  referrer  String?
  eventName String?  @map("event_name")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([websiteId, createdAt])
  @@index([sessionId])
  @@map("events")
}

model MonitorCheck {
  id           String   @id @default(cuid())
  websiteId    String   @map("website_id")
  website      Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  status       String
  responseMs   Int?     @map("response_ms")
  statusCode   Int?     @map("status_code")
  sslValid     Boolean? @map("ssl_valid")
  sslExpiresAt DateTime? @map("ssl_expires_at")
  sslDaysLeft  Int?     @map("ssl_days_left")
  sslIssuer    String?  @map("ssl_issuer")
  error        String?
  checkedAt    DateTime @default(now()) @map("checked_at")

  @@index([websiteId, checkedAt])
  @@map("monitor_checks")
}

model Server {
  id         String         @id @default(cuid())
  name       String
  hostname   String
  agentToken String         @unique @map("agent_token")
  userId     String         @map("user_id")
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @map("created_at")
  metrics    ServerMetric[]

  @@index([userId])
  @@map("servers")
}

model ServerMetric {
  id         String   @id @default(cuid())
  serverId   String   @map("server_id")
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  cpuPercent Float?   @map("cpu_percent")
  memUsed    BigInt?  @map("mem_used")
  memTotal   BigInt?  @map("mem_total")
  diskUsed   BigInt?  @map("disk_used")
  diskTotal  BigInt?  @map("disk_total")
  load1      Float?   @map("load_1")
  uptimeSec  BigInt?  @map("uptime_sec")
  reportedAt DateTime @default(now()) @map("reported_at")

  @@index([serverId, reportedAt])
  @@map("server_metrics")
}
