# 复制为 .env.production 并修改所有密钥与域名

# 数据库（与 docker-compose.prod.yml 中 postgres 服务一致）
POSTGRES_USER=litestats
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=litestats

# 应用密钥（务必更换为随机字符串）
AUTH_SECRET=change-me-to-a-random-64-char-string
HASH_SALT=change-me-to-another-random-string

# 首次部署可 seed 默认管理员（admin / litestats），之后请立即改密并注册 Passkey
RUN_DB_SEED=true

# WebAuthn / Passkey — 必须与对外访问域名完全一致
DOMAIN=stats.example.com
CADDY_EMAIL=you@example.com
WEBAUTHN_RP_ID=stats.example.com
WEBAUTHN_ORIGIN=https://stats.example.com
WEBAUTHN_RP_NAME=LiteStats

# DATABASE_URL 由 docker-compose.prod.yml 自动注入，无需手动设置

# GeoIP 查询（采集时解析访客国家，默认 cnip.io）
GEOIP_API_URL=https://api.cnip.io/geoip

# 国旗资源：本地 /flags（public/flags）或 flagcdn.io CDN
# NEXT_PUBLIC_FLAG_BASE_URL=/flags
# NEXT_PUBLIC_FLAG_BASE_URL=https://flagcdn.io

# 站点 favicon（默认 favicon.la）
# NEXT_PUBLIC_FAVICON_BASE_URL=https://favicon.la
